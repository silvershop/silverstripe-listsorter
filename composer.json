{
  "name": "silvershop/silverstripe-listsorter",
  "description": "Easily provide front-end sorting controls for SilverStripe lists",
  "type": "silverstripe-vendormodule",
  "keywords": [
    "sort",
    "datalist",
    "arraylist",
    "list",
    "sortable"
  ],
  "replace": {
    "burnbright/silverstripe-listsorter": "2.*"
  },
  "require": {
    "silverstripe/framework": "^6"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "3.x-dev"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11",
    "squizlabs/php_codesniffer": "^3.0",
    "cambis/silverstan": "^2.0"
  },
  "scripts": {
    "lint": "phpcs",
    "lint:fix": "phpcbf",
    "test": "phpunit",
    "analyse": "phpstan analyse"
  },
  "autoload": {
    "psr-4": {
      "SilverShop\\ListSorter\\": "src/",
      "SilverShop\\ListSorter\\Tests\\": "tests/php/"
    }
  },
  "prefer-stable": true,
  "minimum-stability": "dev",
  "license": "BSD-3-Clause",
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "phpstan/extension-installer": true,
      "silverstripe/vendor-plugin": true
    }
  }
}
